POSTGRES_DB=goexchange
POSTGRES_USER=goexchange
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

GOEXCHANGE_JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
GOEXCHANGE_ENABLE_DEV_TOOLS=false
GOEXCHANGE_DEV_TOOLS_TOKEN=
GOEXCHANGE_ENABLE_UPBIT=false

# EC2에 붙인 도메인이 있으면 도메인을 쓰고, 없으면 퍼블릭 IPv4 주소를 씁니다.
# 예: http://13.125.10.20 또는 https://exchange.example.com
GOEXCHANGE_PUBLIC_ORIGIN=http://CHANGE_ME_EC2_PUBLIC_IP
GOEXCHANGE_CORS_ALLOWED_ORIGINS=http://CHANGE_ME_EC2_PUBLIC_IP
GOEXCHANGE_WS_ALLOWED_ORIGINS=http://CHANGE_ME_EC2_PUBLIC_IP

BACKEND_IMAGE=ghcr.io/go-exchange-project/go-exchange-back:latest
FRONTEND_IMAGE=ghcr.io/go-exchange-project/go-exchange-front:latest
BACKEND_PORT=8080
FRONTEND_PORT=80
